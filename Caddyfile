# Caddy reverse proxy for goje.local
# TLS terminated here using mkcert wildcard cert.
# Gunicorn runs HTTP on 127.0.0.1:5055 behind this.
#
# URLs:
#   https://lab.goje.local:8443        → scheduler app
#   https://portfolio.goje.local:8443  → portfolio page
#   https://goje.local:8443            → redirects to lab

{
	auto_https off
	http_port 8080
	https_port 8443
}

https://goje.local:8443 {
	tls /Users/vishvajeetn/Documents/Scheduler/Main/cert.pem /Users/vishvajeetn/Documents/Scheduler/Main/key.pem
	redir https://lab.goje.local:8443{uri} permanent
}

https://lab.goje.local:8443 {
	tls /Users/vishvajeetn/Documents/Scheduler/Main/cert.pem /Users/vishvajeetn/Documents/Scheduler/Main/key.pem
	reverse_proxy 127.0.0.1:5055
}

https://portfolio.goje.local:8443 {
	tls /Users/vishvajeetn/Documents/Scheduler/Main/cert.pem /Users/vishvajeetn/Documents/Scheduler/Main/key.pem
	reverse_proxy 127.0.0.1:5055
}
