#!/bin/bash
# PRISM central-bare pre-receive gate — FAST MODE.
#
# Two speeds:
#   FAST (default): runs `smoke` only (~1s). Used on every branch push.
#   FULL:           runs full `sanity` wave (~20s). Used on tag pushes
#                   and when PRISM_FULL_GATE=1 is set.
#
# Fast mode cuts push latency from ~20s to ~2s while keeping the
# critical-path regression check (smoke hits 33 routes × 3 roles).
# Full sanity still runs on tags and can be triggered manually.

set -u

WORKTREE="${PRISM_WORKTREE:-$HOME/Documents/Scheduler/Main}"
VENV_PY="$WORKTREE/.venv/bin/python"

# Read refs from stdin to detect tag pushes.
IS_TAG=0
while read -r _old _new ref; do
  case "$ref" in refs/tags/*) IS_TAG=1 ;; esac
done

if [ ! -x "$VENV_PY" ]; then
  echo "[pre-receive] no venv — gate skipped"
  exit 0
fi

# Pick the wave: full sanity on tags or when forced, smoke otherwise.
if [ "$IS_TAG" -eq 1 ] || [ "${PRISM_FULL_GATE:-0}" = "1" ]; then
  WAVE="sanity"
  echo "[pre-receive] FULL sanity gate (tag push)…"
else
  WAVE="smoke"
  echo "[pre-receive] fast gate (smoke only, ~1s)…"
fi

LOG="$(mktemp -t prism_gate.XXXXXX)"
trap 'rm -f "$LOG"' EXIT

if [ "$WAVE" = "sanity" ]; then
  CMD="wave sanity"
else
  CMD="run $WAVE"
fi
if ( cd "$WORKTREE" && "$VENV_PY" -m crawlers $CMD ) > "$LOG" 2>&1; then
  grep -E '^▶|overall exit code' "$LOG" || true
  echo "[pre-receive] $WAVE green — push accepted"
  exit 0
fi

echo "[pre-receive] ╳ $WAVE FAILED — push REFUSED"
cat "$LOG"
echo "[pre-receive] fix and retry."
exit 1
