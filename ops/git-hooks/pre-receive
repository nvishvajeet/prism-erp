#!/bin/bash
# PRISM central-bare pre-receive gate.
#
# Runs the `sanity` crawler wave in the laptop working copy and
# refuses the push if any strategy fails. Two-tier safety:
#
#   1. Working copy: scripts/smoke_test.py (fast, run before commit).
#   2. Bare:         sanity wave (slower, run on every push).
#
# The hook lives in the working tree at ops/git-hooks/pre-receive
# for reproducibility; `ops/git-hooks/install.sh` copies it into
# ~/.claude/git-server/lab-scheduler.git/hooks/pre-receive on the
# laptop and makes it executable.
#
# The hook is a no-op on any host that does not have the laptop's
# working tree, so the mini and any other pull-only consumers
# never trip it.

set -u

WORKTREE="${PRISM_WORKTREE:-$HOME/Documents/Scheduler/Main}"
VENV_PY="$WORKTREE/.venv/bin/python"

# Drain git's per-ref stdin (format: <old_sha> <new_sha> <ref>).
# We don't need per-ref logic — the working tree is one state.
cat > /dev/null

# No working tree? Skip gracefully. This keeps the hook safe to
# mirror to any other bare on any other host.
if [ ! -x "$VENV_PY" ]; then
  echo "[pre-receive] no venv at $VENV_PY — sanity gate skipped"
  exit 0
fi

echo "[pre-receive] running sanity wave in $WORKTREE…"
LOG="$(mktemp -t prism_sanity.XXXXXX)"
trap 'rm -f "$LOG"' EXIT

if ( cd "$WORKTREE" && "$VENV_PY" -m crawlers wave sanity ) > "$LOG" 2>&1; then
  # Tail the summary lines so a passing push still gets a proof
  # line in the terminal.
  grep -E '^▶|overall exit code' "$LOG" || true
  echo "[pre-receive] sanity green — push accepted"
  exit 0
fi

echo "[pre-receive] ╳ SANITY FAILED — push REFUSED"
echo "──────────────── crawler output ────────────────"
cat "$LOG"
echo "─────────────────────────────────────────────────"
echo "[pre-receive] fix the failing strategies and retry the push."
exit 1
