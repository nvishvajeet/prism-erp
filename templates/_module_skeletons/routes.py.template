@app.route("/__MODULE__/new", methods=["GET", "POST"])
@login_required
def __MODULE___new():
    """Create a new __ENTITY__."""
    if request.method == "POST":
        db = get_db()
        db.execute(
            "INSERT INTO __MODULE__ (name, status, created_at) VALUES (?, 'draft', datetime('now'))",
            (request.form["name"],)
        )
        db.commit()
        flash("__ENTITY_TITLE__ created.", "success")
        return redirect(url_for("__MODULE___list"))
    return render_template("__MODULE___new.html", V=V)
