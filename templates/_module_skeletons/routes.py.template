@app.route("/__MODULE__")
@login_required
def __MODULE___list():
    """List all __ENTITY_PLURAL__."""
    db = get_db()
    items = db.execute("SELECT * FROM __MODULE__ ORDER BY created_at DESC").fetchall()
    return render_template("__MODULE___list.html", items=items, V=V)


@app.route("/__MODULE__/<int:__ENTITY___id>", methods=["GET", "POST"])
@login_required
def __MODULE___detail(__ENTITY___id):
    """Show detail page for a single __ENTITY__."""
    db = get_db()
    item = db.execute("SELECT * FROM __MODULE__ WHERE id = ?", (__ENTITY___id,)).fetchone()
    if not item:
        abort(404)
    events = db.execute(
        "SELECT * FROM __MODULE___events WHERE __ENTITY___id = ? ORDER BY created_at DESC",
        (__ENTITY___id,)
    ).fetchall()
    stats = {
        "total": db.execute("SELECT COUNT(*) FROM __MODULE__").fetchone()[0],
        "active": db.execute("SELECT COUNT(*) FROM __MODULE__ WHERE status = 'active'").fetchone()[0],
        "completed": db.execute("SELECT COUNT(*) FROM __MODULE__ WHERE status = 'completed'").fetchone()[0],
    }
    return render_template("__MODULE___detail.html", item=item, events=events, stats=stats, V=V)


